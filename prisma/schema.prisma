generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Product {
  id             String   @id @default(cuid())
  externalId     String
  brand          String
  title          String
  handle         String
  productUrl     String
  category       String
  // Primary colorway (first / cheapest) — kept as top-level for easy sorting/display
  colorName      String
  colorBucket    String
  imageUrl       String
  price          Float    // minimum price across all colorways
  compareAtPrice Float?
  onSale         Boolean  @default(false)
  // All colorways serialised as JSON (array of Colorway objects)
  colorways      String   @default("[]")
  // Additional sellers (Nordstrom, REI) JSON: [{ seller, displayName, url, price, compareAtPrice, onSale }]
  sellers        String   @default("[]")
  // Comma-separated list of unique color buckets across all colorways — used for filtering
  colorBuckets   String   @default("")
  // Union of all sizes across all colorways (JSON)
  sizes          String   @default("[]")
  inStock        Boolean   @default(true)
  isNew          Boolean   @default(false)
  firstSeenAt    DateTime  @default(now())
  lastSeenAt     DateTime  @default(now())
  priceDroppedAt DateTime?
  updatedAt      DateTime  @updatedAt
  // Admin fields
  categoryOverride String?
  isHidden         Boolean  @default(false)
  // Relations
  collections      CollectionProduct[]
  heroFor          Collection[]        @relation("CollectionHero")
  articles         ArticleProduct[]

  @@unique([brand, externalId])
  @@index([brand])
  @@index([category])
  @@index([colorBucket])
  @@index([onSale])
  @@index([isNew])
  @@index([isHidden])
}

model ScrapeLog {
  id            String    @id @default(cuid())
  brand         String
  startedAt     DateTime  @default(now())
  finishedAt    DateTime?
  status        String
  itemsFound    Int?
  itemsUpserted Int?
  errorMessage  String?
}

model Collection {
  id            String              @id @default(cuid())
  name          String
  slug          String              @unique
  description   String?
  isActive      Boolean             @default(false)
  heroProductId String?
  heroProduct   Product?            @relation("CollectionHero", fields: [heroProductId], references: [id])
  products      CollectionProduct[]
  lastEditedAt  DateTime            @updatedAt
  lastEditedBy  String?             // Supabase user ID of last editor

  @@index([isActive])
}

model Article {
  id           String           @id @default(cuid())
  title        String
  subtitle     String?
  body         String           @default("")
  isActive     Boolean          @default(false)
  publishedAt  DateTime?
  lastEditedAt DateTime         @updatedAt
  lastEditedBy String?
  images       ArticleImage[]
  products     ArticleProduct[]

  @@index([isActive])
  @@index([publishedAt])
}

model ArticleImage {
  id        String  @id @default(cuid())
  articleId String
  imageUrl  String
  position  Int
  altText   String?
  article   Article @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@index([articleId, position])
}

model ArticleProduct {
  id        String  @id @default(cuid())
  articleId String
  productId String
  position  Int
  article   Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([articleId, productId])
  @@index([articleId, position])
}

model CollectionProduct {
  id           String     @id @default(cuid())
  collectionId String
  productId    String
  position     Int
  addedAt      DateTime   @default(now())
  collection   Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  product      Product    @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([collectionId, productId])
  @@index([collectionId, position])
}
