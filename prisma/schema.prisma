generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Product {
  id             String   @id @default(cuid())
  externalId     String
  brand          String
  title          String
  handle         String
  productUrl     String
  category       String
  // Primary colorway (first / cheapest) — kept as top-level for easy sorting/display
  colorName      String
  colorBucket    String
  imageUrl       String
  price          Float    // minimum price across all colorways
  compareAtPrice Float?
  onSale         Boolean  @default(false)
  // All colorways serialised as JSON (array of Colorway objects)
  colorways      String   @default("[]")
  // Comma-separated list of unique color buckets across all colorways — used for filtering
  colorBuckets   String   @default("")
  // Union of all sizes across all colorways (JSON)
  sizes          String   @default("[]")
  inStock        Boolean  @default(true)
  isNew          Boolean  @default(false)
  firstSeenAt    DateTime @default(now())
  lastSeenAt     DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([brand, externalId])
  @@index([brand])
  @@index([category])
  @@index([colorBucket])
  @@index([onSale])
  @@index([isNew])
}

model ScrapeLog {
  id            String    @id @default(cuid())
  brand         String
  startedAt     DateTime  @default(now())
  finishedAt    DateTime?
  status        String
  itemsFound    Int?
  itemsUpserted Int?
  errorMessage  String?
}
